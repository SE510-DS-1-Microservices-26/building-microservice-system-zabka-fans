{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Resilience": {
    "TimeoutSeconds": 10,
    "Retry": {
      "MaxAttempts": 3,
      "BaseDelaySeconds": 1
    },
    "CircuitBreaker": {
      "MinimumThroughput": 5,
      "FailureRatio": 0.5,
      "BreakDurationSeconds": 30,
      "SamplingDurationSeconds": 60
    }
  },
  "ReverseProxy": {
    "Routes": {
      "users-read-route": {
        "ClusterId": "core",
        "Order": 10,
        "Match": {
          "Path": "/users/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "users-write-route": {
        "ClusterId": "users",
        "Order": 10,
        "Match": {
          "Path": "/users/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },
      "internships-route": {
        "ClusterId": "core",
        "Order": 10,
        "Match": {
          "Path": "/internships/{**catch-all}"
        }
      },
      "applications-route": {
        "ClusterId": "core",
        "Order": 10,
        "Match": {
          "Path": "/applications/{**catch-all}"
        }
      },
      "core-health-route": {
        "ClusterId": "core",
        "Order": 1,
        "Match": {
          "Path": "/core/health"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/core"
          }
        ]
      },
      "users-health-route": {
        "ClusterId": "users",
        "Order": 1,
        "Match": {
          "Path": "/users/health"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "core-swagger-route": {
        "ClusterId": "core",
        "Order": 1,
        "Match": {
          "Path": "/core/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/core"
          }
        ]
      },
      "users-swagger-route": {
        "ClusterId": "users",
        "Order": 1,
        "Match": {
          "Path": "/users/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/users"
          }
        ]
      },
      "it-provision-health-route": {
        "ClusterId": "it-provision",
        "Order": 1,
        "Match": {
          "Path": "/it-provision/health"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/it-provision"
          }
        ]
      },
      "it-provision-swagger-route": {
        "ClusterId": "it-provision",
        "Order": 1,
        "Match": {
          "Path": "/it-provision/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/it-provision"
          }
        ]
      },
      "notification-health-route": {
        "ClusterId": "notification",
        "Order": 1,
        "Match": {
          "Path": "/notification/health"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notification"
          }
        ]
      },
      "notification-swagger-route": {
        "ClusterId": "notification",
        "Order": 1,
        "Match": {
          "Path": "/notification/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notification"
          }
        ]
      }
    },
    "Clusters": {
      "users": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5236"
          }
        }
      },
      "core": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5227"
          }
        }
      },
      "it-provision": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5150"
          }
        }
      },
      "notification": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5274"
          }
        }
      }
    }
  }
}
