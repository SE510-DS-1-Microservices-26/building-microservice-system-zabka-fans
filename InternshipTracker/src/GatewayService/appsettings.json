{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "users-read-route": {
        "ClusterId": "core",
        "Match": {
          "Path": "/users/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "users-write-route": {
        "ClusterId": "users",
        "Match": {
          "Path": "/users/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      },
      "internships-route": {
        "ClusterId": "core",
        "Match": {
          "Path": "/internships/{**catch-all}"
        }
      },
      "applications-route": {
        "ClusterId": "core",
        "Match": {
          "Path": "/applications/{**catch-all}"
        }
      },
      "core-health-route": {
        "ClusterId": "core",
        "Match": {
          "Path": "/core/health"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/core"
          }
        ]
      },
      "users-health-route": {
        "ClusterId": "users",
        "Match": {
          "Path": "/users/health"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "core-swagger-route": {
        "ClusterId": "core",
        "Match": {
          "Path": "/core/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/core"
          }
        ]
      },
      "users-swagger-route": {
        "ClusterId": "users",
        "Match": {
          "Path": "/users/swagger/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/users"
          }
        ]
      }
    },
    "Clusters": {
      "users": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5236"
          }
        }
      },
      "core": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5227"
          }
        }
      }
    }
  }
}
